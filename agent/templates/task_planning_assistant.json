{
  "id": 61,
  "title": {"en": "Task planning assistant", "zh": "任务规划助手"},
  "description": {"en": "Turn a natural-language request into intent, context, task tree, checks, decision, and report.", "zh": "把自然语言请求转换成意图、上下文、任务树、前置条件检查、决策和报告。"},
  "canvas_type": "Recommended",
  "canvas_types": ["Recommended", "Agent", "Other"],
  "canvas_category": "agent_canvas",
  "dsl": {
    "components": {
      "begin": {
        "downstream": ["GoalIntentClassifier:Intent"],
        "obj": {"component_name": "Begin", "params": {"enablePrologue": true, "inputs": {"task_request": {"name": "任务要求", "type": "line", "optional": false, "options": []}, "workspace_root": {"name": "工作区根目录", "type": "line", "optional": true, "options": []}, "task_id": {"name": "可执行任务 ID", "type": "line", "optional": true, "options": []}}, "mode": "conversational", "prologue": "请输入一个需要拆解和规划的任务。"}},
        "upstream": []
      },
      "GoalIntentClassifier:Intent": {
        "downstream": ["TaskContextCollector:Context"],
        "obj": {"component_name": "GoalIntentClassifier", "params": {"request": "{begin@task_request}"}},
        "upstream": ["begin"]
      },
      "TaskContextCollector:Context": {
        "downstream": ["TaskPlanner:Plan"],
        "obj": {"component_name": "TaskContextCollector", "params": {"goal_intent": "{GoalIntentClassifier:Intent@goal_intent}", "root": "{begin@workspace_root}", "query": "{begin@task_request}"}},
        "upstream": ["GoalIntentClassifier:Intent"]
      },
      "TaskPlanner:Plan": {
        "downstream": ["PreconditionChecker:Check"],
        "obj": {"component_name": "TaskPlanner", "params": {"goal_intent": "{GoalIntentClassifier:Intent@goal_intent}", "context_bundle": "{TaskContextCollector:Context@context_bundle}"}},
        "upstream": ["TaskContextCollector:Context"]
      },
      "PreconditionChecker:Check": {
        "downstream": ["TaskExecutor:Execute"],
        "obj": {"component_name": "PreconditionChecker", "params": {"task": "{TaskPlanner:Plan@root_task}", "runtime_context": "{TaskContextCollector:Context@context_bundle}"}},
        "upstream": ["TaskPlanner:Plan"]
      },
      "TaskExecutor:Execute": {
        "downstream": ["TaskResultVerifier:Verify"],
        "obj": {"component_name": "TaskExecutor", "params": {"task_id": "{begin@task_id}", "runtime_context": "{TaskContextCollector:Context@context_bundle}", "root": "{begin@workspace_root}"}},
        "upstream": ["PreconditionChecker:Check"]
      },
      "TaskResultVerifier:Verify": {
        "downstream": ["TaskReflection:Reflect"],
        "obj": {"component_name": "TaskResultVerifier", "params": {"task": "{TaskPlanner:Plan@root_task}", "result": "{TaskExecutor:Execute@result}"}},
        "upstream": ["TaskExecutor:Execute"]
      },
      "TaskReflection:Reflect": {
        "downstream": ["ReplanDecider:Decide"],
        "obj": {"component_name": "TaskReflection", "params": {"task": "{TaskPlanner:Plan@root_task}", "result": "{TaskExecutor:Execute@result}", "verification": "{TaskResultVerifier:Verify@verification}"}},
        "upstream": ["TaskResultVerifier:Verify"]
      },
      "ReplanDecider:Decide": {
        "downstream": ["TaskExecutionReportComposer:Report"],
        "obj": {"component_name": "ReplanDecider", "params": {"task": "{TaskPlanner:Plan@root_task}", "verification": "{TaskResultVerifier:Verify@verification}", "reflection": "{TaskReflection:Reflect@reflection}"}},
        "upstream": ["TaskReflection:Reflect"]
      },
      "TaskExecutionReportComposer:Report": {
        "downstream": ["Message:Answer"],
        "obj": {"component_name": "TaskExecutionReportComposer", "params": {"title": "任务规划报告", "goal_intent": "{GoalIntentClassifier:Intent@goal_intent}", "context_bundle": "{TaskContextCollector:Context@context_bundle}", "task_plan": "{TaskPlanner:Plan@task_plan}", "precondition_result": "{PreconditionChecker:Check@precondition_result}", "execution_result": "{TaskExecutor:Execute@execution_result}", "verification": "{TaskResultVerifier:Verify@verification}", "decision": "{ReplanDecider:Decide@decision}"}},
        "upstream": ["ReplanDecider:Decide"]
      },
      "Message:Answer": {
        "downstream": [],
        "obj": {"component_name": "Message", "params": {"content": ["{TaskExecutionReportComposer:Report@markdown}"]}},
        "upstream": ["TaskExecutionReportComposer:Report"]
      }
    },
    "globals": {"sys.conversation_turns": 0, "sys.date": "", "sys.file_assets": [], "sys.files": [], "sys.history": [], "sys.query": "", "sys.user_id": ""},
