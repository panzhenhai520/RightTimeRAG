{
  "id": 46,
  "title": {
    "en": "Policy version diff assistant",
    "zh": "制度版本差异比对智能体"
  },
  "description": {
    "en": "Compare two policy versions by paragraph, clause, and risk wording, then generate a traceable version-diff report.",
    "zh": "输入两个制度版本文件路径后，智能体会按段落、条款和风险表述生成版本差异报告。"
  },
  "canvas_type": "Recommended",
  "canvas_types": ["Recommended", "Agent", "Other"],
  "canvas_category": "agent_canvas",
  "dsl": {
    "components": {
      "begin": {
        "downstream": ["DocumentNormalizer:Old", "DocumentNormalizer:New"],
        "obj": {
          "component_name": "Begin",
          "params": {
            "enablePrologue": true,
            "inputs": {
              "workspace_root": {"name": "工作区根目录", "type": "line", "optional": true, "options": []},
              "old_policy_path": {"name": "旧版制度路径", "type": "line", "optional": false, "options": []},
              "new_policy_path": {"name": "新版制度路径", "type": "line", "optional": false, "options": []},
              "output_formats": {"name": "输出格式", "type": "line", "optional": true, "options": []}
            },
            "mode": "conversational",
            "prologue": "请输入旧版和新版制度文件路径。"
          }
        },
        "upstream": []
      },
      "DocumentNormalizer:Old": {"downstream": ["ClauseExtractor:Old", "DocumentDiff:Paragraphs"], "obj": {"component_name": "DocumentNormalizer", "params": {"root": "{begin@workspace_root}", "path": "{begin@old_policy_path}", "max_bytes": 1048576, "chunk_chars": 2400}}, "upstream": ["begin"]},
      "DocumentNormalizer:New": {"downstream": ["ClauseExtractor:New", "DocumentDiff:Paragraphs"], "obj": {"component_name": "DocumentNormalizer", "params": {"root": "{begin@workspace_root}", "path": "{begin@new_policy_path}", "max_bytes": 1048576, "chunk_chars": 2400}}, "upstream": ["begin"]},
      "ClauseExtractor:Old": {"downstream": ["DocumentSemanticComparer:VersionMatch"], "obj": {"component_name": "ClauseExtractor", "params": {"document": "{DocumentNormalizer:Old@document}", "min_chars": 4}}, "upstream": ["DocumentNormalizer:Old"]},
      "ClauseExtractor:New": {"downstream": ["DocumentSemanticComparer:VersionMatch"], "obj": {"component_name": "ClauseExtractor", "params": {"document": "{DocumentNormalizer:New@document}", "min_chars": 4}}, "upstream": ["DocumentNormalizer:New"]},
      "DocumentDiff:Paragraphs": {"downstream": ["DocumentCompareReportComposer:Report"], "obj": {"component_name": "DocumentDiff", "params": {"left_document": "{DocumentNormalizer:Old@document}", "right_document": "{DocumentNormalizer:New@document}", "granularity": "paragraphs"}}, "upstream": ["DocumentNormalizer:Old", "DocumentNormalizer:New"]},
      "DocumentSemanticComparer:VersionMatch": {"downstream": ["DocumentConflictDetector:Regression"], "obj": {"component_name": "DocumentSemanticComparer", "params": {"left_items": "{ClauseExtractor:Old@clauses}", "right_items": "{ClauseExtractor:New@clauses}", "min_score": 0.2}}, "upstream": ["ClauseExtractor:Old", "ClauseExtractor:New"]},
      "DocumentConflictDetector:Regression": {"downstream": ["DocumentCompareReportComposer:Report"], "obj": {"component_name": "DocumentConflictDetector", "params": {"standard_items": "{ClauseExtractor:Old@clauses}", "target_items": "{ClauseExtractor:New@clauses}", "min_score": 0.18}}, "upstream": ["DocumentSemanticComparer:VersionMatch"]},
      "DocumentCompareReportComposer:Report": {
        "downstream": ["Message:Answer"],
        "obj": {"component_name": "DocumentCompareReportComposer", "params": {"title": "制度版本差异比对报告", "filename": "policy_version_diff_report", "output_formats": "{begin@output_formats}", "documents": ["{DocumentNormalizer:Old@document}", "{DocumentNormalizer:New@document}"], "diff": "{DocumentDiff:Paragraphs@diff}", "matches": "{DocumentSemanticComparer:VersionMatch@matches}", "conflicts": "{DocumentConflictDetector:Regression@conflicts}", "missing_requirements": "{DocumentConflictDetector:Regression@missing_requirements}"}},
        "upstream": ["DocumentDiff:Paragraphs", "DocumentConflictDetector:Regression"]
      },
      "Message:Answer": {"downstream": [], "obj": {"component_name": "Message", "params": {"content": ["{DocumentCompareReportComposer:Report@markdown}"]}}, "upstream": ["DocumentCompareReportComposer:Report"]}
    },
    "globals": {"sys.conversation_turns": 0, "sys.date": "", "sys.file_assets": [], "sys.files": [], "sys.history": [], "sys.query": "", "sys.user_id": ""},
    "graph": {
      "edges": [
        {"id": "e-begin-old", "source": "begin", "sourceHandle": "start", "target": "DocumentNormalizer:Old", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-begin-new", "source": "begin", "sourceHandle": "start", "target": "DocumentNormalizer:New", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-old-clause", "source": "DocumentNormalizer:Old", "sourceHandle": "start", "target": "ClauseExtractor:Old", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-new-clause", "source": "DocumentNormalizer:New", "sourceHandle": "start", "target": "ClauseExtractor:New", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-old-diff", "source": "DocumentNormalizer:Old", "sourceHandle": "start", "target": "DocumentDiff:Paragraphs", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-new-diff", "source": "DocumentNormalizer:New", "sourceHandle": "start", "target": "DocumentDiff:Paragraphs", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-old-match", "source": "ClauseExtractor:Old", "sourceHandle": "start", "target": "DocumentSemanticComparer:VersionMatch", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-new-match", "source": "ClauseExtractor:New", "sourceHandle": "start", "target": "DocumentSemanticComparer:VersionMatch", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-match-regression", "source": "DocumentSemanticComparer:VersionMatch", "sourceHandle": "start", "target": "DocumentConflictDetector:Regression", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-regression-report", "source": "DocumentConflictDetector:Regression", "sourceHandle": "start", "target": "DocumentCompareReportComposer:Report", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-diff-report", "source": "DocumentDiff:Paragraphs", "sourceHandle": "start", "target": "DocumentCompareReportComposer:Report", "targetHandle": "end", "data": {"isHovered": false}},
        {"id": "e-report-message", "source": "DocumentCompareReportComposer:Report", "sourceHandle": "start", "target": "Message:Answer", "targetHandle": "end", "data": {"isHovered": false}}
      ],
      "nodes": []
    },
    "history": []
  }
}
