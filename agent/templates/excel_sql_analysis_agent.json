{
  "id": 42,
  "title": {
    "en": "Excel and SQL analysis assistant",
    "de": "Excel- und SQL-Analyseassistent",
    "zh": "Excel 汇总与 SQL 分析助手"
  },
  "description": {
    "en": "Upload an Excel or CSV file, calculate a business value from total columns and a coefficient, query a database with that value, then generate a downloadable analysis report.",
    "de": "Laden Sie eine Excel- oder CSV-Datei hoch, berechnen Sie aus Summenspalten und einem Koeffizienten einen Geschaftswert, fragen Sie damit eine Datenbank ab und erzeugen Sie einen Analysebericht.",
    "zh": "上传 Excel 或 CSV 后，自动识别合计类字段并乘以手工输入系数得到 B，再用 B 执行只读 SQL 查询，最终生成分析报告和下载文档。"
  },
  "canvas_type": "Recommended",
  "canvas_types": ["Recommended", "Agent", "Other"],
  "canvas_category": "agent_canvas",
  "dsl": {
    "components": {
      "begin": {
        "downstream": ["ExcelProcessor:Aggregate"],
        "obj": {
          "component_name": "Begin",
          "params": {
            "enablePrologue": true,
            "inputs": {
              "source_file": {
                "name": "Excel 或 CSV 文件",
                "type": "file",
                "optional": false,
                "options": []
              },
              "coefficient": {
                "name": "计算系数",
                "type": "integer",
                "optional": false,
                "options": []
              }
            },
            "mode": "conversational",
            "prologue": "你好！请上传 Excel 或 CSV 文件，并填写计算系数。创建后请在 ExeSQL 节点中配置数据库连接和业务 SQL。"
          }
        },
        "upstream": []
      },
      "ExcelProcessor:Aggregate": {
        "downstream": ["ExcelProcessor:CalculateB", "Agent:ExplainData"],
        "obj": {
          "component_name": "ExcelProcessor",
          "params": {
            "aggregate_coefficient": 1,
            "aggregate_column_keywords": ["合计", "总计", "金额合计", "total", "sum", "amount"],
            "aggregate_result_name": "合计值",
            "input_files": ["sys.file_assets", "begin@source_file_file_assets"],
            "join_on": "",
            "merge_strategy": "concat",
            "operation": "aggregate",
            "output_filename": "excel_aggregate_result",
            "output_format": "xlsx",
            "outputs": {
              "aggregate": {
                "type": "object",
                "value": {}
              },
              "attachment": {
                "type": "object",
                "value": {}
              },
              "data": {
                "type": "object",
                "value": {}
              },
              "downloads": {
                "type": "Array<Object>",
                "value": []
              },
              "markdown": {
                "type": "string",
                "value": ""
              },
              "result": {
                "type": "number",
                "value": 0
              },
              "summary": {
                "type": "string",
                "value": ""
              }
            },
            "sheet_selection": "all",
            "transform_data": "",
            "transform_instructions": ""
          }
        },
        "upstream": ["begin"]
      },
      "ExcelProcessor:CalculateB": {
        "downstream": ["ExeSQL:QueryRecords", "Agent:ExplainData"],
        "obj": {
          "component_name": "ExcelProcessor",
          "params": {
            "aggregate_column_keywords": ["合计", "总计", "金额合计", "total", "sum", "amount"],
            "aggregate_coefficient": 1,
            "aggregate_result_name": "B",
            "calculation_value": "{ExcelProcessor:Aggregate@result}",
            "calculation_coefficient": "{begin@coefficient}",
            "calculation_result_name": "B",
            "input_files": [],
            "join_on": "",
            "merge_strategy": "concat",
            "operation": "calculate",
            "output_filename": "excel_calculation_result",
            "output_format": "xlsx",
            "outputs": {
              "aggregate": {
                "type": "object",
                "value": {}
              },
              "attachment": {
                "type": "object",
                "value": {}
              },
              "data": {
                "type": "object",
                "value": {}
              },
              "downloads": {
                "type": "Array<Object>",
                "value": []
              },
              "markdown": {
                "type": "string",
                "value": ""
              },
              "result": {
                "type": "number",
                "value": 0
              },
              "summary": {
                "type": "string",
                "value": ""
              }
            },
            "sheet_selection": "all",
            "transform_data": "",
            "transform_instructions": ""
          }
        },
        "upstream": ["ExcelProcessor:Aggregate"]
      },
      "ExeSQL:QueryRecords": {
        "downstream": ["Agent:ExplainData"],
        "obj": {
          "component_name": "ExeSQL",
          "params": {
            "database": "",
            "db_type": "mysql",
            "host": "",
            "max_records": 1024,
            "outputs": {
              "formalized_content": {
                "type": "string",
                "value": ""
              },
              "json": {
                "type": "Array<Object>",
                "value": []
              }
            },
            "password": "",
            "port": 3306,
            "sql": "SELECT * FROM your_table WHERE A > {ExcelProcessor:CalculateB@result}",
            "username": ""
          }
        },
        "upstream": ["ExcelProcessor:CalculateB"]
      },
      "Agent:ExplainData": {
        "downstream": ["DocGenerator:DataReportDoc"],
        "obj": {
          "component_name": "Agent",
          "params": {
            "delay_after_error": 1,
            "description": "",
            "exception_default_value": "",
            "exception_goto": [],
            "exception_method": "",
            "frequencyPenaltyEnabled": false,
            "frequency_penalty": 0.7,
            "llm_id": "qwen-max@Tongyi-Qianwen",
            "maxTokensEnabled": false,
            "max_retries": 3,
            "max_rounds": 5,
            "max_tokens": 2048,
            "mcp": [],
            "message_history_window_size": 8,
            "outputs": {
              "content": {
                "type": "string",
                "value": ""
              }
            },
            "presencePenaltyEnabled": false,
            "presence_penalty": 0.4,
            "prompts": [
              {
                "content": "用户需求：{sys.query}\n\nExcel 合计字段汇总结果：\n{ExcelProcessor:Aggregate@markdown}\n\nB 的计算结果：\n{ExcelProcessor:CalculateB@markdown}\n\nSQL 查询结果：\n{ExeSQL:QueryRecords@formalized_content}\n\n请基于上面的真实计算和查询结果做业务解读。",
                "role": "user"
              }
            ],
            "sys_prompt": "你是数据分析助手。你需要基于代码节点和 SQL 节点已经计算出的真实结果进行分析，不要自己猜测数据。\n\n输出要求：\n1. 先说明 B 的计算过程和数值。\n2. 概述 SQL 返回记录的数量、关键字段和异常点。\n3. 给出可执行的业务观察和建议。\n4. 如果 SQL 没有返回数据或数据库未配置，明确提示需要配置 ExeSQL 节点。",
            "temperature": 0.1,
            "temperatureEnabled": false,
            "tools": [],
            "topPEnabled": false,
            "top_p": 0.3,
            "user_prompt": "",
            "visual_files_var": ""
          }
        },
        "upstream": ["ExeSQL:QueryRecords", "ExcelProcessor:Aggregate", "ExcelProcessor:CalculateB"]
      },
      "DocGenerator:DataReportDoc": {
        "downstream": ["Message:DataAnswer"],
        "obj": {
          "component_name": "DocGenerator",
          "params": {
            "add_page_numbers": true,
            "add_timestamp": true,
            "content": "{Agent:ExplainData@content}",
            "filename": "数据分析报告",
            "font_size": 12,
            "footer_text": "",
            "header_text": "数据分析报告",
            "include_download_info_in_content": false,
            "output_format": "docx",
            "outputs": {
              "attachment": {
                "type": "object",
